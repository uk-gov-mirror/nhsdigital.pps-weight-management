{% extends "web/layout/base.jinja" %}

{% from "web/macros/layout.jinja" import two_thirds_column_start, two_thirds_column_end %}
{% from "web/macros/forms.jinja" import form_error_summary, continue_button, back_link %}

{% set pageName = service.serviceName %}

{% block beforeContent %}
  {{ back_link("/listing") }}
{% endblock %}

{% block content %}
<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-two-thirds">
    <div class="app-handy-flex-container app-collapser">
      <div>
        <div class="app-roundel app-detail">
          <img src="{{ static('assets/images/services/') }}{{ service.logoImage }}" alt="{{ service.serviceName | default('Service name') }} logo" />
        </div>
      </div>
      <div>
        <h1 class="nhsuk-u-margin-bottom-3">{{ service.serviceName | default('Service name') }}</h1>
        <p class="nhsuk-body-l">
          {{ service.description | default('description') | striptags | safe }}
        </p>
      </div>
    </div>
  </div>
</div>

<hr class="nhsuk-section-break--m">

{% if service.promoImage %}
  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-one-half">
      <h2>What it is</h2>
      {{ service.whatItIs | safe }}

      <h2>How it works</h2>
      {{ service.howItWorks | safe }}

      <h2>What it could do for you</h2>
      {{ service.whatItCouldDo | safe }}

      {% if service.helpsWith|default([])|length > 0 %}
        <h3>{{ service.serviceName }} can help you with:</h3>
        <ul>
          {% for item in service.helpsWith %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      {% endif %}

    </div>
    <div class="nhsuk-grid-column-one-half app-util-suppress-print">
      <img src="{{ static('assets/images/services/') }}{{ service.promoImage }}" width="100%" alt="">
    </div>
  </div>
{% else %}
  <!-- Variable is null, undefined, or empty string -->
  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">

      <h2>What it is</h2>
      {{ service.whatItIs | default('What it is') | safe }}

      <h2>How it works</h2>
      {{ service.howItWorks | default('How it works') | safe }}

      <h2>What it could do for you</h2>
      {{ service.whatItCouldDo | default('What it could do') | safe }}

      {% if service.helpsWith|default([])|length > 0 %}
        <h3>{{ service.serviceName | default('service name') }} can help you with:</h3>
        <ul>
          {% for item in service.helpsWith %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      {% endif %}

    </div>
  </div>
{% endif %}


<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-two-thirds nhsuk-u-margin-top-6">

    {% if service.whoItsFor|default([])|length > 0 %}
      <h2>Who it’s for</h2>
      <ul>
        {% for item in service.whoItsFor %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if service.whoItsNotFor|default([])|length > 0 %}
      <h2>Who it’s not for</h2>
      <ul>
        {% for item in service.whoItsNotFor %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if service.mitigationType[0] == 'primary care' and service.actionType != 'clinical referral' %}
      <div class="nhsuk-inset-text">
        <span class="nhsuk-u-visually-hidden">Information: </span>
        <p>Speak to a GP if you’re worried about your health before you start {{ service.serviceName }}</p>
      </div>
    {% endif %}

    {% if service.howMuchTime|default([])|length > 0 %}
      <h2>How much time you’ll need</h2>
      <ul>
        {% for item in service.howMuchTime %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if service.howToAccess|default([])|length > 0 %}
      <h2>How you can access it</h2>
      <ul>
        {% for item in service.howToAccess %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if service.cost|default([])|length > 0 %}
      <h2>Cost</h2>
      <ul>
        {% for item in service.cost %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    <h2>Get started</h2>

    {% if service.actionType == 'action link' %}
      {{ actionLink({
        "text": service.actionText,
        "href": service.actionUrl
      }) }}
    {% endif %}

    {% if service.actionType == 'app store' %}
      <p>Get the {{ service.serviceName }} app on the App Store or Google Play:</p>
      <div class="app-store-cta-block">
        <div class="app-store-icon-container">
          <a href="{{ service.appStoreUrl }}" class="app-store-link">
            <img src="{{ static('assets/images/utility/apple-store-badge.svg') }}" alt="Download the {{ service.serviceName }} app on the App Store" />
          </a>
        </div>

        <div class="app-store-icon-container">
          <a href="{{ service.playStoreUrl }}" class="app-store-link">
            <img src="{{ static('assets/images/utility/google-play-badge.svg') }}" alt="Get the {{ service.serviceName }} app on Google Play" />
          </a>
        </div>
      </div>
    {% endif %}

    {% if service.actionType == 'clinical referral' %}
      {% set descriptionHtml %}
        <p>Ask your GP or health professional to refer you to {{ service.serviceName }}.</p>
      {% endset %}
      {{ card({
        "type": "non-urgent",
        "heading": "Speak to your GP",
        "descriptionHtml": descriptionHtml
      }) }}
    {% endif %}

    {% if service.moreInfoUrl %}
      <p>
        <a href="{{ service.moreInfoUrl }}" target="_blank">
          Find out more about {{ service.serviceName }}
        </a>
        <span class="nhsuk-body-s app-util-suppress-print">(opens in a new tab or window)</span>
      </p>
    {% endif %}


