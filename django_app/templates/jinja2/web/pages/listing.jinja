{% extends "web/layout/base.jinja" %}

{% from "web/macros/layout.jinja" import two_thirds_column_start, two_thirds_column_end %}
{% from "web/macros/forms.jinja" import form_error_summary, continue_button, back_link %}


{% set pageName = "Activities for you" %}

{% block content %}
<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-full">
    <h1>Activities for you</h1>
  </div>
</div>

<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-full">
    {{ button({
      "html": '
        <svg class="app-icon app-icon--filter" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" width="2rem" height="2rem" viewBox="0 0 24 24">
          <path d="M3.507 7.258c-.081.047-.094.14-.094.688 0 .595.008.64.119.718.106.074.997.083 8.468.083s8.362-.009 8.468-.083c.111-.078.119-.124.119-.69 0-.48-.018-.624-.084-.69-.076-.076-.918-.084-8.493-.082-5.613.001-8.441.019-8.503.056m2.628 4.098c-.03.057-.055.347-.055.644 0 .297.025.587.055.644.054.101.176.103 5.865.103s5.811-.002 5.865-.103c.03-.057.055-.347.055-.644 0-.297-.025-.587-.055-.644-.054-.101-.176-.103-5.865-.103s-5.811.002-5.865.103m2.641 4.016c-.061.087-.083.253-.083.628s.022.541.083.628l.083.119h3.169c3.078 0 3.17-.003 3.223-.103.031-.057.056-.356.056-.663 0-.438-.019-.578-.084-.644-.074-.074-.441-.084-3.224-.084h-3.14l-.083.119" />
        </svg>
        Show filters
      ',
      "classes": "nhsuk-button--secondary app-filter-toggle-button js-toggle-button",
      "type": "button"
    }) }}
  </div>
</div>

<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-one-quarter">

    <!-- start FILTERS area -->
    <div id="js-listing-filters" tabindex="-1" role="dialog" aria-modal="true">
      <form method="post" class="app-listing-filters-form">
        {{ csrf_input }}
        <input type="hidden" name="page_size" id="hidden-page-size" value="{{ pagination.page_size }}">
        <input type="hidden" name="page" value="1">
        <input type="hidden" name="distance" id="hidden-distance" value="{{ distance }}">
		
        {{ button({
          "text": "Close",
          "classes": "nhsuk-button--secondary js-toggle-button",
          "type": "button"
        }) }}

        <h2 class="nhsuk-heading-m nhsuk-u-font-weight-normal">Filters</h2>

        <!-- Goals -->
        {{ checkboxes({
          "idPrefix": "goals",
          "name": "goals",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Goals",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "goals.exercise",
              "text": "Exercise"
            },
            {
              "value": "goals.healthy_eating",
              "text": "Healthy eating"
            }
          ],
          "values": data.goals if data.goals else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- Cost -->
        {{ checkboxes({
          "idPrefix": "cost",
          "name": "cost",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Cost",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "cost.free",
              "text": "Free"
            },
            {
              "value": "cost.initial_discount",
              "text": "Initial discount or offer"
            },
            {
              "value": "cost.permanent_discount",
              "text": "Permanent discount"
            },
            {
              "value": "cost.paid_for",
              "text": "Paid for"
            }
          ],
          "values": data.cost if data.cost else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- Timetabling -->
        {{ checkboxes({
          "idPrefix": "timetable",
          "name": "timetable",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Timetable",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "timetable.scheduled",
              "text": "Scheduled"
            },
            {
              "value": "timetable.self_paced",
              "text": "Self-paced"
            }
          ],
          "values": data.timetable if data.timetable else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- Location -->
        {{ checkboxes({
          "idPrefix": "location",
          "name": "location",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Location",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "location.venue_or_a_place",
              "text": "At a venue or place"
            },
            {
              "value": "location.wherever_works_for_you",
              "text": "Wherever works for you"
            }
          ],
          "values": data.location if data.location else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- How taught -->
        {{ checkboxes({
          "idPrefix": "taught",
          "name": "taught",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "How you like to be taught",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "taught.taught_by_a_person",
              "text": "Taught by a person"
            },
            {
              "value": "taught.self_led",
              "text": "Self-led"
            }
          ],
          "values": data.taught if data.taught else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- Who with -->
        {{ checkboxes({
          "idPrefix": "who_with",
          "name": "who_with",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Who with",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "who_with.alone",
              "text": "Alone"
            },
            {
              "value": "who_with.in_a_group",
              "text": "In a group"
            }
          ],
          "values": data.who_with if data.who_with else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- How channel -->
        {{ checkboxes({
          "idPrefix": "channel",
          "name": "channel",
          "classes": "nhsuk-checkboxes--small",
          "fieldset": {
            "legend": {
              "text": "Access",
              "classes": "nhsuk-fieldset__legend--s"
            }
          },
          "items": [
            {
              "value": "channel.in_real_life",
              "text": "In real life"
            },
            {
              "value": "channel.digital",
              "text": "Digital"
            }
          ],
          "values": data.channel if data.channel else undefined
        }) }}

        <hr class="nhsuk-section-break--m">

        <!-- style="width: 100%" -->
        {{ button({
          "text": "Update",
          "classes": "nhsuk-button--full-width"
        }) }}

        {{ button({
          "text": "Close",
          "classes": "nhsuk-button--secondary js-toggle-button",
          "type": "button"
        }) }}
      </form>

    </div>
  </div>

  <!-- start results column -->

  <div class="nhsuk-grid-column-three-quarters">

    {% set count = results.total %}

    {% if count == 0 %}
      <h2 class="nhsuk-heading-m nhsuk-u-font-weight-normal">
        We found no matches
      </h2>

    {% else %}
      <div class="nhsuk-u-margin-bottom-4">
        <h2 class="nhsuk-heading-m nhsuk-u-font-weight-normal nhsuk-u-margin-bottom-2">
          We found {{ count }} match{{ 'es' if count != 1 }}
        </h2>
        
        {% if pagination.total_results > 0 %}
        <p class="nhsuk-body-s nhsuk-u-secondary-text-color">
          Showing {{ pagination.showing_from }} to {{ pagination.showing_to }} of {{ pagination.total_results }}
        </p>
        {% endif %}
      </div>

      <!-- Search distance selector -->
      {% if postcode %}
      <div class="nhsuk-form-group nhsuk-u-margin-bottom-4 app-distance-selector">
        <label class="nhsuk-label nhsuk-u-font-size-16" for="distance-select">
          Local services search distance from your postcode {{ postcode }}:
        </label>
        <select class="nhsuk-select nhsuk-select--auto" id="distance-select" name="distance" onchange="updateDistance(this.value)" >
          {% for d in distance_options %}
          <option value="{{ d }}" {{ 'selected' if d == distance }}>{{ d }} miles</option>
          {% endfor %}
        </select>
      </div>
      {% endif %}
    {% endif %}

    {% for result in results.results %}
    <div class="nhsuk-card nhsuk-card--clickable">
      <div class="nhsuk-card__content">

        <div class="app-handy-flex-container app-collapser">
          <div>
            <div class="app-roundel app-listing">
              <img src=" {{ static('assets/images/services/') }}{{ result.logoImage }}" alt="{{ result.serviceName | default('Service name') }} logo" />
            </div>
          </div>
          <div>
            <h2 class="nhsuk-card__heading nhsuk-heading-s">
              <a class="nhsuk-card__link" href="detail/{{ result.id }}">{{ result.serviceName | default('Service name') }}</a>
            </h2>
            <div class="nhsuk-card__description">
              <p>{{ result.description | default('description') | striptags | safe }}</p>
              <div class="nhsuk-grid-row">
                <dl class="nhsuk-grid-column-one-third app-u-definition-list">
                  <dt class="nhsuk-body-s">What</dt>
                  <dd class="nhsuk-body-m">{{ result.serviceType | default('service type') }}</dd>
                </dl>
                <dl class="nhsuk-grid-column-one-third app-u-definition-list">
                  <dt class="nhsuk-body-s">Cost</dt>
                  <dd class="nhsuk-body-m">{{ result.costText | default('cost') }}</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    {% endfor %}

    <!-- Hidden form for pagination navigation - must be before pagination controls -->
    <form id="pagination-form" method="post" style="display: none;">
      {{ csrf_input }}
      <input type="hidden" name="page" id="pagination-page" value="{{ pagination.current_page }}">
      <input type="hidden" name="page_size" id="pagination-page-size" value="{{ pagination.page_size }}">
      <input type="hidden" name="distance" id="pagination-distance" value="{{ distance }}">
      {% for field in ['goals', 'cost', 'timetable', 'location', 'taught', 'who_with', 'channel'] %}
        {% if data[field] %}
          {% for val in data[field] %}
            <input type="hidden" name="{{ field }}" value="{{ val }}">
          {% endfor %}
        {% endif %}
      {% endfor %}
    </form>

    <!-- Pagination and page size -->
    {% if pagination.total_pages > 1 or pagination.total_results > 0 %}
    <div class="nhsuk-pagination app-pagination-bar">
      {% if pagination.total_pages > 1 %}
      <nav role="navigation" aria-label="Pagination">
        <ul class="nhsuk-pagination__list">
          {% for page_num in pagination.page_range %}
            {% if page_num == -1 %}
              <li class="nhsuk-pagination-item--ellipsis">
                <span class="nhsuk-pagination__link nhsuk-pagination__link--ellipsis">…</span>
              </li>
            {% elif page_num == pagination.current_page %}
              <li class="nhsuk-pagination-item--current">
                <span class="nhsuk-pagination__link nhsuk-pagination__link--current" aria-current="page">{{ page_num }}</span>
              </li>
            {% else %}
              <li class="nhsuk-pagination-item--number">
                <a href="javascript:void(0);" onclick="goToPage({{ page_num }})" class="nhsuk-pagination__link" aria-label="Page {{ page_num }}">{{ page_num }}</a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </nav>
      {% else %}
      <div></div>
      {% endif %}
      
      <!-- Page size selector -->
      <div class="nhsuk-form-group app-page-size-selector">
        <label class="nhsuk-label nhsuk-u-font-size-16" for="page-size-select">
          Results per page:
        </label>
        <select class="nhsuk-select nhsuk-select--auto" id="page-size-select" name="page_size" onchange="updatePageSize(this.value)">
          {% for size in pagination.page_size_options %}
          <option value="{{ size }}" {{ 'selected' if size == pagination.page_size }}>{{ size }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
    {% endif %}

  </div>

</div>

<script>
  // Navigate to a specific page
  function goToPage(pageNum) {
    var paginationForm = document.getElementById('pagination-form');
    if (!paginationForm) {
      console.error('Pagination form not found');
      return;
    }
    
    // Sync current page size and distance from visible dropdowns to hidden form
    var pageSizeSelect = document.getElementById('page-size-select');
    var distanceSelect = document.getElementById('distance-select');
    
    if (pageSizeSelect) {
      document.getElementById('pagination-page-size').value = pageSizeSelect.value;
    }
    if (distanceSelect) {
      document.getElementById('pagination-distance').value = distanceSelect.value;
    }
    
    document.getElementById('pagination-page').value = pageNum;
    paginationForm.submit();
  }

  // Page size dropdown handler
  function updatePageSize(newSize) {
    var paginationForm = document.getElementById('pagination-form');
    if (!paginationForm) {
      console.error('Pagination form not found');
      return;
    }
    
    // Sync distance from visible dropdown
    var distanceSelect = document.getElementById('distance-select');
    if (distanceSelect) {
      document.getElementById('pagination-distance').value = distanceSelect.value;
    }
    
    document.getElementById('pagination-page-size').value = newSize;
    document.getElementById('pagination-page').value = '1'; // Reset to page 1
    paginationForm.submit();
  }

  // Distance dropdown handler
  function updateDistance(newDistance) {
    var paginationForm = document.getElementById('pagination-form');
    if (!paginationForm) {
      console.error('Pagination form not found');
      return;
    }
    
    // Sync page size from visible dropdown
    var pageSizeSelect = document.getElementById('page-size-select');
    if (pageSizeSelect) {
      document.getElementById('pagination-page-size').value = pageSizeSelect.value;
    }
    
    document.getElementById('pagination-distance').value = newDistance;
    document.getElementById('pagination-page').value = '1'; // Reset to page 1
    paginationForm.submit();
  }

  // Filter form setup
  (function() {
    var filterForm = document.querySelector('.app-listing-filters-form');
    if (filterForm) {
      filterForm.addEventListener('submit', function(e) {
        // Sync dropdown values to hidden fields before filter form submits
        var pageSizeSelect = document.getElementById('page-size-select');
        var distanceSelect = document.getElementById('distance-select');
        var hiddenPageSize = document.getElementById('hidden-page-size');
        var hiddenDistance = document.getElementById('hidden-distance');
        
        if (pageSizeSelect && hiddenPageSize) {
          hiddenPageSize.value = pageSizeSelect.value;
        }
        if (distanceSelect && hiddenDistance) {
          hiddenDistance.value = distanceSelect.value;
        }
      });
    }

    // Mobile filter toggle setup
    var buttons = document.querySelectorAll('.js-toggle-button');
    var content = document.getElementById('js-listing-filters');
    var bodyElement = document.getElementsByTagName('body')[0];
    var mediaQuery = window.matchMedia('(max-width: 768px)');

    function toggleContent() {
      if (content) {
        content.classList.toggle('js-show');
        bodyElement.classList.toggle('js-obfuscate');
      }
    }

    function updateToggleBehavior(e) {
      if (e.matches) {
        buttons.forEach(function(button) {
          button.addEventListener('click', toggleContent);
        });
      } else {
        buttons.forEach(function(button) {
          button.removeEventListener('click', toggleContent);
        });
        bodyElement.classList.remove('js-obfuscate');
        if (content) {
          content.classList.remove('js-show');
        }
      }
    }

    updateToggleBehavior(mediaQuery);
    mediaQuery.addEventListener('change', updateToggleBehavior);
  })();
</script>
{% endblock %}