{# Weight management base template #}
{% extends "nhsuk/template.jinja" %}
{% from "nhsuk/components/button/macro.jinja" import button %}
{% from "nhsuk/components/back-link/macro.jinja" import backLink %}
{% from "nhsuk/components/input/macro.jinja" import input %}
{% from "nhsuk/components/error-summary/macro.jinja" import errorSummary %}
{% from "nhsuk/components/checkboxes/macro.jinja" import checkboxes %}
{% from "nhsuk/components/radios/macro.jinja" import radios %}
{% from "nhsuk/components/notification-banner/macro.jinja" import notificationBanner %}
{% from "nhsuk/components/footer/macro.jinja" import footer %}
{% from "nhsuk/components/action-link/macro.jinja" import actionLink %}
{% set assetPath = "/static/assets" %}
{% block pageTitle %}NHS - {{ serviceName }}{% endblock %}
{% block head %}
  {{ super() }}
  <link rel="stylesheet" href="{{ static('nhsuk-frontend.min.css') }}">
  <link rel="stylesheet" href="{{ static('assets/css/main.css') }}">
{% endblock %}
{% block header %}
  {% set showPilotAccount = request.user.is_authenticated and (not request.user.is_staff) and request.pilot_access_registered %}
  {{ header({
    "service": {
    "text": serviceName,
    "href": url("home") 
  },
  "account": ({
  "items": [
  { "text": "Edit my details", "icon": true, "href": url("pilot_access:account") },
  { "text": "Sign out", "href": url("pilot_access:logout") },
  ]
  } if showPilotAccount else none)
  }) }}
{% endblock %}
{% block footer %}
  {{ footer({
    "meta": {
      "items": [
        {
          "text": "Mitigation disclaimer",
          "href": "/"
        },
        {
          "text": "Privacy policy",
          "href": "/"
        }
      ]
    }
  }) }}
  <form id="pilot-logout-form"
        method="post"
        action="{{ url('pilot_access:logout') }}"
        style="display:none">
    {{ csrf_input }}
  </form>
{% endblock %}
{% block bodyEnd %}
  {{ super() }}
  <script type="module">
    import { initAll } from "{{ static('nhsuk-frontend.min.js') }}";
    initAll();

    function interceptLogoutLink() {
      const logoutLink = document.querySelector('.nhsuk-header__account-link[href="/pilot/logout/"]');
      const logoutForm = document.getElementById('pilot-logout-form');

      if (!logoutLink || !logoutForm) {
        return;
      }

      logoutLink.addEventListener('click', function(event) {
        event.preventDefault();
        logoutForm.submit();
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        interceptLogoutLink();
      });
    } else {
      interceptLogoutLink();
    }
  </script>
  {% if request.user.is_authenticated and not request.user.is_staff %}
    <script>
    // Prevent showing cached authenticated pages when navigating back after logout/account deletion
    window.addEventListener('pageshow', function(event) {
      if (event.persisted) {
        // Page was restored from bfcache - reload to check auth status
        window.location.reload();
      }
    });
    </script>
  {% endif %}
  <script src="{{ static('assets/javascript/main.js') }}"></script>
{% endblock %}
