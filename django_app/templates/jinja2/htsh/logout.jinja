{% extends "web/layout/base.jinja" %}

{% block content %}
  <h1 class="nhsuk-heading-l">Signing you out…</h1>

  <form id="logout-form" method="post" action="{{ url('htsh:logout') }}">
    {{ csrf_input }}
    <noscript>
      <button class="nhsuk-button" type="submit">Log out</button>
    </noscript>
  </form>

  <script>
    (function() {
      var f = document.getElementById("logout-form");
      if (f) f.submit();
    })();
  </script>
{% endblock %}
