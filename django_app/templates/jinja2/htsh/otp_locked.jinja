{% extends "web/layout/base.jinja" %}

{% from "web/macros/layout.jinja" import two_thirds_column_start, two_thirds_column_end %}

{% set pageName = "Too many attempts" %}

{% block content %}
  {{ two_thirds_column_start() }}

  <h1 class="nhsuk-heading-l">Too many attempts</h1>

  <div class="nhsuk-warning-callout">
    <h2 class="nhsuk-warning-callout__label">Account temporarily locked</h2>
    <p>
      You have entered an incorrect code too many times. For security reasons, 
      your account has been temporarily locked.
    </p>
  </div>

  <p class="nhsuk-body">
    Please wait {{ lockout_minutes }} minutes before trying again, or request a new verification code.
  </p>

  <p class="nhsuk-body">
    <a class="nhsuk-link" href="{{ url('htsh:magic_link_request') }}">
      Request a new verification code
    </a>
  </p>

  <p class="nhsuk-body">
    <a class="nhsuk-link" href="{{ url('landing') }}">
      Return to start
    </a>
  </p>

  {{ two_thirds_column_end() }}
{% endblock %}
