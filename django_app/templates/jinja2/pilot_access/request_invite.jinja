{% extends "web/layout/base.jinja" %}

{% block content %}
  <h1 class="nhsuk-heading-l">Request an invite</h1>

  {% if rate_limited %}
    <div class="nhsuk-warning-callout">
      <h3 class="nhsuk-warning-callout__label">Too many requests</h3>
      <p>Please wait {{ rate_limit_window_minutes }} minutes and try again.</p>
    </div>
  {% endif %}

  <form method="post">
    {{ csrf_input }}
    <div class="nhsuk-form-group">
      <label class="nhsuk-label" for="id_email">Email address</label>
      {% if form.email.errors %}
        <span class="nhsuk-error-message">{{ form.email.errors[0] }}</span>
      {% endif %}
      <input class="nhsuk-input" id="id_email" name="email" type="email" value="{{ form.email.value() or '' }}">
    </div>

    <button class="nhsuk-button" type="submit">Request invite</button>
  </form>
{% endblock %}
