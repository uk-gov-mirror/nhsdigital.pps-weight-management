{% extends 'web/base.jinja' %}

{% set pageName = "What makes it hard for you to stay healthy?" %}

{% block beforeContent %}
  {{ backLink({
    "href": "/goals",
    "text": "Back"
  }) }}
{% endblock %}

{% block content %}
<div class="nhsuk-grid-row">
  <div class="nhsuk-grid-column-two-thirds">

    {% if error %}
    {{ errorSummary({
      "titleText": "There is a problem",
      "errorList": [
        {
          "text": "Please choose an option",
          "href": "#goals"
        }
      ]
    }) }}
    {% endif %}

    <form method="post">
      {{ csrf_input }}

      {{ checkboxes({
        "idPrefix": "barriers",
        "name": "barriers",
        "errorMessage": {
          "text": "Please choose an option"
        } if error else undefined,
        "fieldset": {
          "legend": {
            "text": "What makes it hard for you to stay healthy?",
            "classes": "nhsuk-fieldset__legend--l",
            "isPageHeading": "true"
          }
        },
        "hint": {
          "text": "Choose as many or as few as you like"
        },
        "items": [
          {
            "value": "too-busy",
            "text": "Too busy",
            "exclusiveGroup": "barriers-list"
          },
          {
            "value": "too-stressed",
            "text": "Too stressed",
            "exclusiveGroup": "barriers-list"
          },
          {
            "value": "no-support",
            "text": "No support",
            "exclusiveGroup": "barriers-list"
          },
          {
            "value": "no-willpower",
            "text": "No willpower",
            "exclusiveGroup": "barriers-list"
          },
          {
            "value": "tried-before-and-failed",
            "text": "Tried before and failed",
            "exclusiveGroup": "barriers-list"
          },
          {
            "divider": "or"
          },
          {
            "value": "none",
            "text": "None of these",
            "exclusive": "true",
            "exclusiveGroup": "barriers-list"
          }
        ],
        "values": data.barriers if data.barriers else undefined
      }) }}

      {{ button({
        "text": "Continue"
      }) }}

    </form>
  </div>
</div>
{% endblock %}
